{
  "manifest_version": 3,
  "name": "Light MD Viewer",
  "version": "1.0.0",
  "description": "View and edit Markdown files directly in Chrome with syntax highlighting, mermaid diagrams, and split editor.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "file:///*/*.md",
    "file:///*/*.markdown",
    "file:///*/*.mdown"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "file:///*/*.md",
        "file:///*/*.markdown",
        "file:///*/*.mdown"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.js",
        "css/*",
        "lib/*"
      ],
      "matches": ["file:///*"]
    }
  ]
}
